6. TYPY — KĽÚČOVÉ ROZHRANIA (types.ts)

// Zvukový asset z katalógu
interface SoundAsset {
  id: string;                    // "ambient/fileId" | "sfx/fileId" | "music/fileId"
  type: 'ambient' | 'sfx' | 'music';
  filePath: string;              // Absolútna cesta k .ogg
  description: string;           // Popis pre embedding
  keywords: string[];            // Kľúčové slová
  durationSec?: number;          // Dĺžka v sekundách
  loudnessLUFS?: number;         // Pre normalizáciu hlasitosti
}

// Výstup LLM režiséra pre 1 kapitolu
interface SceneAnalysis {
  chapterIndex: number;
  sceneSegments: SceneSegment[];  // 1-6 scén (charIndex, environment, searchSnippets, moods)
  sfxEvents: SfxEvent[];          // SFX eventy (query, charIndex, description)
  timeOfDay: string;
  weather: string;
  moods: string[];
  soundElements: string[];
  intensity: number;              // 0.0 - 1.0
}

// Silence gap z ffprobe
interface SilenceGap {
  startSec: number;
  endSec: number;
  midpointMs: number;            // Sem sa umiestni SFX
}

