# Dialogue Dramatization & Tagging - Most complex, needs full model
LLM_MODEL_DRAMATIZATION=gemini-2.5-flash

# Legacy single model config (fallback)
LLM_MODEL=gemini-2.5-flash

# Gemini TTS model for text-to-speech synthesis
